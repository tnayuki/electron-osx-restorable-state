{
  "name": "electron-osx-restorable-state",
  "version": "0.3.0",
  "description": "macOS State Restoration for Electron — automatically save and restore window position, Space, and custom data",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "src/restorable_state.mm",
    "binding.gyp"
  ],
  "scripts": {
    "install": "node-gyp rebuild",
    "build": "node-gyp rebuild",
    "clean": "node-gyp clean",
    "example": "env -u ELECTRON_RUN_AS_NODE npx electron example/main.js",
    "test": "env -u ELECTRON_RUN_AS_NODE npx electron test/smoke.js",
    "test:e2e": "npx playwright test test/e2e.spec.js",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "macos",
    "spaces",
    "virtual-desktop",
    "window-state",
    "state-restoration",
    "restorable"
  ],
  "author": "Toru Nayuki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tnayuki/electron-osx-restorable-state.git"
  },
  "bugs": {
    "url": "https://github.com/tnayuki/electron-osx-restorable-state/issues"
  },
  "homepage": "https://github.com/tnayuki/electron-osx-restorable-state#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "node-addon-api": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@electron/packager": "^19.1.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "electron": "^40.8.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-gyp": ">=9.0.0",
    "playwright": "^1.59.1"
  },
  "lint-staged": {
    "*.{js,json}": "npx @biomejs/biome check --write --no-errors-on-unmatched"
  }
}
